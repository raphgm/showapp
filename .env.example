# Firebase Configuration
# Get these from: https://console.firebase.google.com → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Daily.co WebRTC (real video calls — free tier: 10,000 min/month)
# Sign up at https://dashboard.daily.co → create a domain → paste it here (without .daily.co)
# e.g. if your URL is https://myapp.daily.co, set VITE_DAILY_DOMAIN=myapp
VITE_DAILY_DOMAIN=
